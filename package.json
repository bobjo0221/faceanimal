<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>동물상 진단소</title>
<link rel="icon" type="image/png" href="data:image/png;base64,">
<link rel="apple-touch-icon" href="data:image/png;base64,">
<meta property="og:title" content="동물상 진단소">
<meta property="og:description" content="사진 속 분위기를 읽어 어울리는 동물상을 찾아드립니다">
<meta property="og:image" content="data:image/png;base64,">
<style>
  :root{
    --paper: #F6F1E4;
    --paper-dark: #ECE3CC;
    --ink: #2E2A22;
    --ink-soft: #6B6253;
    --moss: #5C6B4D;
    --clay: #B9612F;
    --clay-soft: #E8C3A6;
    --line: #C9BB9C;
    --gold: #C49A3A;
  }

  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    background: var(--paper);
    color: var(--ink);
    font-family: 'Noto Serif KR', serif;
    -webkit-tap-highlight-color: transparent;
  }

  body {
    background-image:
      radial-gradient(circle at 20% 10%, rgba(0,0,0,0.025) 0, transparent 45%),
      radial-gradient(circle at 80% 90%, rgba(0,0,0,0.03) 0, transparent 50%);
  }

  .wrap {
    max-width: 460px;
    margin: 0 auto;
    min-height: 100vh;
    padding: 28px 22px 60px;
    position: relative;
  }

  /* ---------- Header ---------- */
  header {
    text-align: center;
    margin-bottom: 22px;
  }

  .mascot {
    width: 84px;
    height: auto;
    margin-bottom: 6px;
    filter: drop-shadow(0 6px 10px rgba(0,0,0,0.12));
  }

  .eyebrow {
    font-family: 'Noto Sans KR', sans-serif;
    font-size: 11px;
    letter-spacing: 0.32em;
    color: var(--moss);
    font-weight: 600;
  }

  h1 {
    font-size: 30px;
    font-weight: 700;
    margin: 8px 0 4px;
    letter-spacing: -0.01em;
  }

  .sub {
    font-family: 'Noto Sans KR', sans-serif;
    font-size: 13px;
    color: var(--ink-soft);
    line-height: 1.6;
  }

  .divider {
    width: 64px;
    height: 2px;
    background: var(--gold);
    margin: 16px auto;
    opacity: 0.6;
  }

  /* ---------- Stage (camera/preview) ---------- */
  .stage {
    position: relative;
    width: 100%;
    aspect-ratio: 3/4;
    border-radius: 18px;
    overflow: hidden;
    background: var(--paper-dark);
    border: 1px solid var(--line);
    box-shadow: 0 1px 0 rgba(255,255,255,0.5) inset, 0 10px 24px -16px rgba(0,0,0,0.35);
  }

  .stage video,
  .stage img,
  .stage canvas {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .stage-empty {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    color: var(--ink-soft);
    font-family: 'Noto Sans KR', sans-serif;
    padding: 30px;
    text-align: center;
  }

  .stage-empty svg { width: 56px; height: 56px; opacity: 0.55; }
  .stage-empty p { font-size: 13px; margin: 0; line-height: 1.6; }

  .stage-frame {
    position: absolute;
    inset: 14px;
    border: 1.5px dashed rgba(46,42,34,0.28);
    border-radius: 14px;
    pointer-events: none;
    transition: opacity 0.3s;
  }

  .stage.has-media .stage-frame { opacity: 0; }

  .corner-tag {
    position: absolute;
    top: 10px;
    left: 10px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 4px 10px;
    font-family: 'Noto Sans KR', sans-serif;
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--ink-soft);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .stage.has-media .corner-tag { opacity: 1; }

  /* ---------- Face guide circle ---------- */
  .face-guide {
    position: absolute;
    left: 50%;
    top: 42%;
    width: 58%;
    aspect-ratio: 1/1;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    border: 3px solid var(--gold);
    box-shadow: 0 0 0 3px rgba(196,154,58,0.18), 0 0 18px rgba(196,154,58,0.25);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 5;
  }

  .face-guide.show { opacity: 1; }

  .face-guide.locked {
    border-color: var(--clay);
    box-shadow: 0 0 0 3px rgba(185,97,47,0.18), 0 0 18px rgba(185,97,47,0.3);
    animation: pulseLock 1.1s ease-out;
  }

  .face-guide::before,
  .face-guide::after {
    content: "";
    position: absolute;
    width: 14px;
    height: 14px;
    border-color: inherit;
  }

  .face-tag {
    position: absolute;
    left: 50%;
    top: 42%;
    transform: translate(-50%, calc(-50% + 38%));
    background: var(--gold);
    color: #fff;
    font-family: 'Noto Sans KR', sans-serif;
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 3px 11px;
    border-radius: 999px;
    white-space: nowrap;
    opacity: 0;
    transition: opacity 0.4s ease, background 0.3s;
    z-index: 6;
    pointer-events: none;
  }

  .face-tag.show { opacity: 1; }
  .face-tag.locked { background: var(--clay); }

  @keyframes pulseLock {
    0% { transform: translate(-50%, -50%) scale(1); }
    35% { transform: translate(-50%, -50%) scale(1.06); }
    100% { transform: translate(-50%, -50%) scale(1); }
  }

  /* ---------- Controls ---------- */
  .controls {
    display: flex;
    gap: 10px;
    margin-top: 16px;
  }

  button {
    font-family: 'Noto Sans KR', sans-serif;
    font-weight: 600;
    border: none;
    cursor: pointer;
    border-radius: 12px;
    padding: 14px 16px;
    font-size: 14px;
    transition: transform 0.15s, box-shadow 0.15s, background 0.2s;
  }

  button:active { transform: scale(0.97); }

  .btn-primary {
    flex: 1;
    background: var(--moss);
    color: var(--paper);
    box-shadow: 0 6px 16px -8px rgba(92,107,77,0.6);
  }

  .btn-secondary {
    flex: 1;
    background: transparent;
    color: var(--ink);
    border: 1.4px solid var(--line);
  }

  .btn-ghost {
    width: 100%;
    background: transparent;
    color: var(--ink-soft);
    font-size: 12.5px;
    padding: 10px;
    text-decoration: underline;
    text-decoration-color: var(--line);
  }

  input[type="file"] { display: none; }

  /* ---------- Diagnose button ---------- */
  .diagnose-row {
    margin-top: 14px;
  }

  .btn-diagnose {
    width: 100%;
    background: var(--clay);
    color: #fff;
    padding: 16px;
    font-size: 15px;
    border-radius: 12px;
    box-shadow: 0 8px 20px -10px rgba(185,97,47,0.65);
    letter-spacing: 0.02em;
  }

  .btn-diagnose:disabled {
    background: var(--clay-soft);
    color: #fff;
    box-shadow: none;
    cursor: not-allowed;
  }

  /* ---------- Loading ---------- */
  .loading-text {
    text-align: center;
    font-family: 'Noto Sans KR', sans-serif;
    font-size: 13px;
    color: var(--ink-soft);
    margin-top: 14px;
    min-height: 18px;
  }

  /* ---------- Result ---------- */
  .result {
    margin-top: 26px;
    border-top: 1px solid var(--line);
    padding-top: 26px;
    display: none;
  }

  .result.show { display: block; animation: rise 0.5s ease; }

  @keyframes rise {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .result-card {
    background: var(--paper-dark);
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 26px 22px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .result-card::before {
    content: "";
    position: absolute;
    top: -40%;
    right: -20%;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, var(--clay-soft) 0%, transparent 70%);
    opacity: 0.5;
  }

  .stamp {
    font-family: 'Noto Sans KR', sans-serif;
    font-size: 10.5px;
    letter-spacing: 0.28em;
    color: var(--clay);
    font-weight: 700;
    position: relative;
  }

  .animal-emoji {
    font-size: 64px;
    margin: 14px 0 6px;
    position: relative;
    filter: drop-shadow(0 6px 10px rgba(0,0,0,0.15));
  }

  .animal-name {
    font-size: 28px;
    font-weight: 700;
    margin: 0 0 4px;
    position: relative;
  }

  .animal-hanja {
    font-family: 'Noto Sans KR', sans-serif;
    font-size: 12px;
    color: var(--ink-soft);
    margin-bottom: 16px;
    position: relative;
  }

  .match-bar-wrap {
    margin: 0 auto 18px;
    max-width: 220px;
    position: relative;
  }

  .match-label {
    font-family: 'Noto Sans KR', sans-serif;
    font-size: 11px;
    color: var(--ink-soft);
    display: flex;
    justify-content: space-between;
    margin-bottom: 6px;
  }

  .match-track {
    height: 8px;
    background: rgba(46,42,34,0.1);
    border-radius: 999px;
    overflow: hidden;
  }

  .match-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--gold), var(--clay));
    border-radius: 999px;
    width: 0%;
    transition: width 1.1s cubic-bezier(.2,.8,.2,1);
  }

  .desc {
    font-family: 'Noto Sans KR', sans-serif;
    font-size: 14px;
    line-height: 1.75;
    color: var(--ink);
    position: relative;
    padding: 0 4px;
  }

  .traits {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    justify-content: center;
    margin-top: 16px;
    position: relative;
  }

  .trait {
    font-family: 'Noto Sans KR', sans-serif;
    font-size: 11.5px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 5px 12px;
    color: var(--moss);
    font-weight: 600;
  }

  .retry-row {
    margin-top: 16px;
    display: flex;
    gap: 10px;
  }

  .disclaimer {
    margin-top: 22px;
    font-family: 'Noto Sans KR', sans-serif;
    font-size: 11px;
    line-height: 1.7;
    color: var(--ink-soft);
    text-align: center;
    opacity: 0.85;
    padding: 0 10px;
  }

  .disclaimer strong { color: var(--ink); }

  canvas#hiddenCanvas { display: none; }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { animation: none !important; transition: none !important; }
  }

  /* Focus visibility */
  button:focus-visible {
    outline: 2px solid var(--moss);
    outline-offset: 2px;
  }
</style>
</head>
<body>

<div class="wrap">

  <header>
    <img class="mascot" src="data:image/png;base64," alt="동물상 진단소 마스코트">
    <div class="eyebrow">ANIMAL FACE READING</div>
    <h1>동물상 진단소</h1>
    <p class="sub">사진 속 분위기를 읽어 어울리는 동물상을<br>찾아드립니다 · 재미로 보는 결과입니다</p>
    <div class="divider"></div>
  </header>

  <div class="stage" id="stage">
    <div class="stage-frame"></div>
    <div class="corner-tag" id="cornerTag">분석 대기</div>
    <div class="stage-empty" id="stageEmpty">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
        <path d="M4 7h2.5L8 4.5h8L17.5 7H20a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1Z"/>
        <circle cx="12" cy="13" r="3.4"/>
      </svg>
      <p>카메라를 켜거나<br>사진을 올려서 시작해요</p>
    </div>
    <video id="video" autoplay playsinline style="display:none;"></video>
    <img id="photo" style="display:none;" alt="업로드한 사진">
    <div class="face-guide" id="faceGuide"></div>
    <div class="face-tag" id="faceTag">얼굴 인식 중</div>
  </div>

  <div class="controls" id="initialControls">
    <button class="btn-primary" id="btnCamera">카메라 켜기</button>
    <button class="btn-secondary" id="btnUpload">사진 올리기</button>
  </div>
  <input type="file" id="fileInput" accept="image/*">

  <div class="controls" id="captureControls" style="display:none;">
    <button class="btn-secondary" id="btnRetake">다시 찍기</button>
    <button class="btn-primary" id="btnShot">촬영하기</button>
  </div>

  <div class="diagnose-row">
    <button class="btn-diagnose" id="btnDiagnose" disabled>먼저 사진을 준비해주세요</button>
  </div>

  <div class="loading-text" id="loadingText"></div>

  <canvas id="hiddenCanvas"></canvas>

  <div class="result" id="resultSection">
    <div class="result-card">
      <div class="stamp" id="stamp">동물상 감정 결과</div>
      <div class="animal-emoji" id="animalEmoji">🐶</div>
      <div class="animal-name" id="animalName">강아지상</div>
      <div class="animal-hanja" id="animalHanja">친근함의 아이콘</div>

      <div class="match-bar-wrap">
        <div class="match-label">
          <span>일치도</span>
          <span id="matchPercent">0%</span>
        </div>
        <div class="match-track"><div class="match-fill" id="matchFill"></div></div>
      </div>

      <p class="desc" id="animalDesc"></p>

      <div class="traits" id="animalTraits"></div>
    </div>

    <div class="retry-row">
      <button class="btn-secondary" id="btnAgain" style="flex:1;">다시 진단하기</button>
    </div>

    <p class="disclaimer">
      <strong>안내</strong><br>
      이 결과는 사진의 밝기·색감·구도 등을 무작위 요소와 함께 활용한
      <strong>오락용 콘텐츠</strong>이며, 실제 얼굴 인식이나 생체 정보 분석을
      수행하지 않습니다. 의학적·과학적 근거가 없는 재미용 결과로만
      봐주세요.
    </p>
  </div>

</div>

<script>
(function(){
  const stage = document.getElementById('stage');
  const stageEmpty = document.getElementById('stageEmpty');
  const cornerTag = document.getElementById('cornerTag');
  const video = document.getElementById('video');
  const photo = document.getElementById('photo');
  const fileInput = document.getElementById('fileInput');
  const hiddenCanvas = document.getElementById('hiddenCanvas');

  const initialControls = document.getElementById('initialControls');
  const captureControls = document.getElementById('captureControls');
  const btnCamera = document.getElementById('btnCamera');
  const btnUpload = document.getElementById('btnUpload');
  const btnRetake = document.getElementById('btnRetake');
  const btnShot = document.getElementById('btnShot');
  const btnDiagnose = document.getElementById('btnDiagnose');
  const btnAgain = document.getElementById('btnAgain');
  const loadingText = document.getElementById('loadingText');

  const resultSection = document.getElementById('resultSection');
  const animalEmoji = document.getElementById('animalEmoji');
  const animalName = document.getElementById('animalName');
  const animalHanja = document.getElementById('animalHanja');
  const animalDesc = document.getElementById('animalDesc');
  const animalTraits = document.getElementById('animalTraits');
  const matchFill = document.getElementById('matchFill');
  const matchPercent = document.getElementById('matchPercent');
  const faceGuide = document.getElementById('faceGuide');
  const faceTag = document.getElementById('faceTag');

  let stream = null;
  let mediaReady = false; // true once a photo or live frame is ready to analyze
  let currentImageSource = null; // 'video' | 'photo'

  const ANIMALS = [
    {
      key: 'dog', emoji: '🐶', name: '강아지상', hanja: '친근함의 아이콘',
      desc: '둥글둥글한 인상에 표정이 살아있는 편이에요. 처음 보는 사람도 금방 편하게 만드는, 친근하고 다정한 분위기가 느껴져요.',
      traits: ['친근함', '활발함', '사교적']
    },
    {
      key: 'cat', emoji: '🐱', name: '고양이상', hanja: '도시적인 분위기',
      desc: '선이 또렷하고 분위기가 시크해요. 무심한 듯하지만 자세히 보면 매력이 묻어나는, 도시적이고 세련된 인상이에요.',
      traits: ['시크함', '세련됨', '도시적']
    },
    {
      key: 'fox', emoji: '🦊', name: '여우상', hanja: '센스 있는 매력',
      desc: '눈매가 또렷하고 분위기에 영리함이 묻어나요. 똑똑하고 눈치 빠른, 살짝 새침한 매력을 가진 인상이에요.',
      traits: ['영리함', '매력적', '눈치빠름']
    },
    {
      key: 'rabbit', emoji: '🐰', name: '토끼상', hanja: '사랑스러운 인상',
      desc: '동글동글하고 순한 느낌이 강해요. 보는 사람을 무장해제시키는, 사랑스럽고 포근한 분위기를 가지고 있어요.',
      traits: ['사랑스러움', '순함', '포근함']
    },
    {
      key: 'deer', emoji: '🦌', name: '사슴상', hanja: '청순한 분위기',
      desc: '눈이 크고 분위기가 맑아요. 차분하면서도 우아한, 청순하고 단정한 느낌을 주는 인상이에요.',
      traits: ['청순함', '우아함', '차분함']
    },
    {
      key: 'bear', emoji: '🐻', name: '곰상', hanja: '믿음직한 존재감',
      desc: '윤곽이 부드럽고 존재감이 든든해요. 보고 있으면 마음이 편해지는, 듬직하고 따뜻한 분위기를 가진 인상이에요.',
      traits: ['듬직함', '따뜻함', '편안함']
    }
  ];

  function setStageHasMedia(has){
    stage.classList.toggle('has-media', has);
    stageEmpty.style.display = has ? 'none' : 'flex';
  }

  let faceGuideTimer = null;

  function showFaceGuideSearching(){
    clearTimeout(faceGuideTimer);
    faceGuide.classList.remove('locked');
    faceTag.classList.remove('locked');
    faceTag.textContent = '얼굴 인식 중';
    faceGuide.classList.add('show');
    faceTag.classList.add('show');
  }

  function lockFaceGuide(){
    clearTimeout(faceGuideTimer);
    faceGuide.classList.add('show');
    faceTag.classList.add('show');
    faceGuide.classList.add('locked');
    faceTag.classList.add('locked');
    faceTag.textContent = '얼굴 인식 완료';
  }

  function hideFaceGuide(){
    clearTimeout(faceGuideTimer);
    faceGuide.classList.remove('show', 'locked');
    faceTag.classList.remove('show', 'locked');
  }

  function showCaptureUI(){
    initialControls.style.display = 'none';
    captureControls.style.display = 'flex';
  }

  function showInitialUI(){
    initialControls.style.display = 'flex';
    captureControls.style.display = 'none';
  }

  function enableDiagnose(label){
    btnDiagnose.disabled = false;
    btnDiagnose.textContent = label || '동물상 진단하기';
  }

  function disableDiagnose(label){
    btnDiagnose.disabled = true;
    btnDiagnose.textContent = label || '먼저 사진을 준비해주세요';
  }

  async function startCamera(){
    try{
      stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' }, audio: false });
      video.srcObject = stream;
      video.style.display = 'block';
      photo.style.display = 'none';
      setStageHasMedia(true);
      cornerTag.textContent = '실시간 카메라';
      showCaptureUI();
      mediaReady = false;
      currentImageSource = null;
      disableDiagnose('사진을 촬영해주세요');
      hideFaceGuide();
      faceGuideTimer = setTimeout(showFaceGuideSearching, 700);
    }catch(err){
      cornerTag.textContent = '';
      alert('카메라를 사용할 수 없어요. 브라우저 권한을 확인해주시거나, 사진 올리기를 이용해주세요.');
    }
  }

  function stopCamera(){
    if(stream){
      stream.getTracks().forEach(t => t.stop());
      stream = null;
    }
  }

  function takeShot(){
    const w = video.videoWidth, h = video.videoHeight;
    if(!w || !h) return;
    hiddenCanvas.width = w;
    hiddenCanvas.height = h;
    const ctx = hiddenCanvas.getContext('2d');
    ctx.translate(w, 0);
    ctx.scale(-1, 1); // mirror to match preview
    ctx.drawImage(video, 0, 0, w, h);

    photo.src = hiddenCanvas.toDataURL('image/png');
    photo.style.display = 'block';
    video.style.display = 'none';
    stopCamera();

    cornerTag.textContent = '촬영 완료';
    mediaReady = true;
    currentImageSource = 'photo';
    enableDiagnose();
    showInitialUI();
    btnCamera.textContent = '카메라 다시 켜기';
    lockFaceGuide();
  }

  function handleFile(file){
    if(!file) return;
    const reader = new FileReader();
    reader.onload = function(e){
      photo.src = e.target.result;
      photo.style.display = 'block';
      video.style.display = 'none';
      stopCamera();
      setStageHasMedia(true);
      cornerTag.textContent = '사진 업로드 완료';
      mediaReady = true;
      currentImageSource = 'photo';
      enableDiagnose();
      showInitialUI();
      lockFaceGuide();
    };
    reader.readAsDataURL(file);
  }

  // --- simple, non-biometric image stats: just brightness / warmth / contrast on the whole image ---
  function analyzeImage(imgEl){
    return new Promise((resolve) => {
      const w = 120, h = 120;
      hiddenCanvas.width = w;
      hiddenCanvas.height = h;
      const ctx = hiddenCanvas.getContext('2d');
      ctx.drawImage(imgEl, 0, 0, w, h);
      let data;
      try{
        data = ctx.getImageData(0, 0, w, h).data;
      }catch(e){
        resolve(null);
        return;
      }
      let rSum=0,gSum=0,bSum=0,brightSum=0,count=0;
      let minB=255,maxB=0;
      for(let i=0;i<data.length;i+=4){
        const r=data[i], g=data[i+1], b=data[i+2];
        const bright = (r+g+b)/3;
        rSum+=r; gSum+=g; bSum+=b; brightSum+=bright; count++;
        if(bright<minB) minB=bright;
        if(bright>maxB) maxB=bright;
      }
      resolve({
        avgR: rSum/count,
        avgG: gSum/count,
        avgB: bSum/count,
        avgBrightness: brightSum/count,
        contrast: maxB-minB
      });
    });
  }

  function pickAnimal(stats){
    // Map simple stats into a seed, then add randomness so result feels playful, not deterministic/biometric
    let seed = 0;
    if(stats){
      const warmth = (stats.avgR - stats.avgB);
      seed = Math.floor(stats.avgBrightness) + Math.floor(warmth) + Math.floor(stats.contrast);
    } else {
      seed = Math.floor(Math.random()*1000);
    }
    const randomness = Math.floor(Math.random() * 1000);
    const index = Math.abs(seed + randomness) % ANIMALS.length;
    const matchScore = 72 + (Math.abs(seed * 7 + randomness) % 23); // 72~94%
    return { animal: ANIMALS[index], match: matchScore };
  }

  function renderResult(animal, match){
    animalEmoji.textContent = animal.emoji;
    animalName.textContent = animal.name;
    animalHanja.textContent = animal.hanja;
    animalDesc.textContent = animal.desc;
    animalTraits.innerHTML = '';
    animal.traits.forEach(t => {
      const span = document.createElement('span');
      span.className = 'trait';
      span.textContent = t;
      animalTraits.appendChild(span);
    });
    matchPercent.textContent = match + '%';
    matchFill.style.width = '0%';
    resultSection.classList.add('show');
    requestAnimationFrame(() => {
      setTimeout(() => { matchFill.style.width = match + '%'; }, 50);
    });
    resultSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  const loadingSteps = ['분위기를 살펴보는 중...', '색감과 표정을 읽는 중...', '가장 닮은 동물상을 고르는 중...'];

  async function runDiagnosis(){
    if(!mediaReady) return;
    btnDiagnose.disabled = true;
    resultSection.classList.remove('show');

    let stepIndex = 0;
    loadingText.textContent = loadingSteps[0];
    const interval = setInterval(() => {
      stepIndex = (stepIndex + 1) % loadingSteps.length;
      loadingText.textContent = loadingSteps[stepIndex];
    }, 550);

    const imgEl = photo.style.display !== 'none' ? photo : null;
    let stats = null;
    if(imgEl && imgEl.src){
      try{ stats = await analyzeImage(imgEl); }catch(e){ stats = null; }
    }

    await new Promise(r => setTimeout(r, 1700));
    clearInterval(interval);
    loadingText.textContent = '';

    const { animal, match } = pickAnimal(stats);
    renderResult(animal, match);
    enableDiagnose();
  }

  btnCamera.addEventListener('click', startCamera);
  btnUpload.addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', (e) => handleFile(e.target.files[0]));
  btnShot.addEventListener('click', takeShot);
  btnRetake.addEventListener('click', startCamera);
  btnDiagnose.addEventListener('click', runDiagnosis);
  btnAgain.addEventListener('click', () => {
    resultSection.classList.remove('show');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  window.addEventListener('beforeunload', stopCamera);
})();
</script>

</body>
</html>
